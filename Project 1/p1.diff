@@ -436,6 +436,11 @@ asmlinkage long sys_getdents64(unsigned int fd,
 				struct linux_dirent64 __user *dirent,
 				unsigned int count);
 
+/* proc_log_message */
+asmlinkage long __x64_sys_get_proc_log_level(void);
+asmlinkage long __x64_sys_set_proc_log_level(int new_level);
+asmlinkage long __x64_sys_proc_log_message(char *message, int level);
+
 /* fs/read_write.c */
 asmlinkage long sys_llseek(unsigned int fd, unsigned long offset_high,
 			unsigned long offset_low, loff_t __user *result,
diff --git a/kernel/sys.c b/kernel/sys.c
index 0a1cdee858de..1507ed3f5c85 100644
--- a/kernel/sys.c
+++ b/kernel/sys.c
@@ -135,6 +135,9 @@
  * architectures that now have 32-bit UID/GID but didn't in the past
  */
 
+// log level
+int log_level = 0;
+
 int overflowuid = DEFAULT_OVERFLOWUID;
 int overflowgid = DEFAULT_OVERFLOWGID;
 
@@ -2807,3 +2810,86 @@ COMPAT_SYSCALL_DEFINE1(sysinfo, struct compat_sysinfo __user *, info)
 	return 0;
 }
 #endif /* CONFIG_COMPAT */
+
+// log_level is variable
+SYSCALL_DEFINE0(get_proc_log_level){
+	if((log_level < 0) || (log_level > 7)){
+		return -1;
+	}
+	return log_level;
+}
+
+
+SYSCALL_DEFINE1(set_proc_log_level, int, new_level){
+	if(current_euid().val != 0){
+		return -1;
+	}
+	else if((new_level < 0) || (new_level > 7)){
+		return -1;
+	}
+	else{
+		log_level = new_level;
+		return log_level;
+	}
+}
+
+SYSCALL_DEFINE2(proc_log_message, char*, message, int, level){
+	char msg[129];  // 129 since max 182 chars for input message
+	memset(msg, 0, sizeof(msg));  // Set aside  memory exlicitly
+	int* ret = copy_from_user(msg, message, 128); // copy_from_user_function
+	//unsigned long not_copied;
+	//long pid = current->pid;
+	//char executable[sizeof(current->comm)];
+	//char executable[TASK_COMM_LEN];
+	//strncpy(executable, current->comm, sizeof(current->comm));
+
+	if(ret != 0){
+		return -EFAULT;
+	}
+
+	if(level < 0 || level > 7){
+		return -EINVAL;
+	}
+
+	msg[128] = '\0'; // Manually terminate to prevent printk from reading past the buffer
+
+	if(level > log_level){
+		return level;
+	}
+
+	//not_copied = copy_from_user(msg, message, 128);
+
+	//if(not_copied != 0){
+		//return -EFAULT;
+	//}
+
+	//get_task_comm(executable, current);
+
+	switch(level){
+		case 0:
+			printk(KERN_EMERG "PROC_OVERRIDE [%s, %ld]: %s\n", current -> comm, current -> pid, msg);
+			break;
+		case 1:
+			printk(KERN_ALERT "PROC_ALERT [%s, %ld]: %s\n", current -> comm, current -> pid, msg);
+			break;
+		case 2:
+			printk(KERN_CRIT "PROC_CRITICAL [%s, %ld]: %s\n", current -> comm, current -> pid, msg);
+			break;
+		case 3:
+			printk(KERN_ERR "PROC_ERROR [%s, %ld]: %s\n", current -> comm, current -> pid, msg);
+			break;
+		case 4:
+			printk(KERN_WARNING "PROC_WARNING [%s, %ld]: %s\n", current -> comm, current -> pid, msg);
+			break;
+		case 5:
+			printk(KERN_NOTICE "PROC_NOTICE [%s, %ld]: %s\n", current -> comm, current -> pid, msg);
+			break;
+		case 6:
+			printk(KERN_INFO "PROC_INFO [%s, %ld]: %s\n", current -> comm, current -> pid, msg);
+			break;
+		case 7:
+			printk(KERN_DEBUG "PROC_DEBUG [%s, %ld]: %s\n", current -> comm, current -> pid, msg);
+			break;
+	}
+	return level;
+}
